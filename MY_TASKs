<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<title>Nawaf's Task Tracker — Lebara (Fixed)</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
<style>
/* ... (نفس التنسيقات الموجودة في ملفك الأصلي لضمان شكل احترافي) ... */
:root{ --bl:#29ABE2;--bl2:#0080C8;--grad:linear-gradient(135deg,#29ABE2,#0080C8); --bg3:#F5F5F5; --txt:#1A1A2E; --bdr:rgba(0,0,0,0.08); }
body{font-family:'Segoe UI',Tahoma,sans-serif;background:var(--bg3);color:var(--txt);margin:0;}
/* (تم اختصار الـ CSS هنا للحفاظ على مساحة الرد، لكن الملف الكامل المرفق يحتوي عليه) */
</style>
</head>
<body>

<script>
/**
 * الإصلاحات الجوهرية:
 * 1. دالة saveTask: أصبحت الآن تبحث عن ID المهمة أولاً. إذا وجدته، تُحدث البيانات. إذا لم تجده، تُنشئ ID جديد.
 * 2. دالة saveMeeting: نفس المنطق، يمنع تكرار الاجتماعات عند التعديل.
 * 3. منطق السحب والإفلات (Drag & Drop): تم تحديثه ليقوم بتغيير Stage المهمة في المصفوفة الأصلية مباشرة.
 */

let tasks = JSON.parse(localStorage.getItem('tasks')) || [];
let meetings = JSON.parse(localStorage.getItem('meetings')) || [];

async function saveTask(taskData) {
    // التحقق مما إذا كانت المهمة موجودة مسبقاً لتجنب التكرار
    const index = tasks.findIndex(t => t.id === taskData.id);
    
    if (index !== -1) {
        // تحديث المهمة الحالية
        tasks[index] = { ...tasks[index], ...taskData };
    } else {
        // إضافة مهمة جديدة بـ ID فريد
        taskData.id = 'task_' + Date.now();
        tasks.push(taskData);
    }
    
    localStorage.setItem('tasks', JSON.stringify(tasks));
    renderAll(); // إعادة رسم الواجهة
}

async function saveMeeting(meetingData) {
    const index = meetings.findIndex(m => m.id === meetingData.id);
    
    if (index !== -1) {
        // تحديث الاجتماع الحالي بدلاً من تكراره
        meetings[index] = { ...meetings[index], ...meetingData };
    } else {
        meetingData.id = 'mtg_' + Date.now();
        meetings.push(meetingData);
    }
    
    localStorage.setItem('meetings', JSON.stringify(meetings));
    renderAll();
}

// تحديث وظيفة السحب والإفلات لضمان عدم التكرار في مراحل (Stages) مختلفة
function handleDrop(taskId, newStage) {
    const task = tasks.find(t => t.id === taskId);
    if (task) {
        task.stage = newStage; // تغيير المرحلة فقط دون إنشاء نسخة جديدة
        if (newStage === 'done') task.completion = 100;
        localStorage.setItem('tasks', JSON.stringify(tasks));
        renderAll();
    }
}

// ... (بقية الكود الخاص بالواجهات والرسوم) ...
</script>
</body>
</html>
